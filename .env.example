# NeuralOps environment configuration
# Copy this file to .env and fill in values for your environment.
# Never commit .env to version control.

# PostgreSQL
POSTGRES_DB=neuralops
POSTGRES_USER=neuralops
POSTGRES_PASSWORD=change_this_in_production

# TimescaleDB
TIMESCALE_DB=neuralops_metrics
TIMESCALE_USER=neuralops
TIMESCALE_PASSWORD=change_this_in_production

# Redis
REDIS_PASSWORD=

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_in_production

# JWT
JWT_SECRET=change_this_to_a_secure_256_bit_secret_before_deploying

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
APP_LOG_LEVEL=DEBUG
